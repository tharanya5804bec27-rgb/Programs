def add_two_numbers(a, b):
    mask = 0xFFFFFFFF
    
    while b & mask != 0:
        carry = (a & b) << 1
        a = a ^ b
        b = carry
    return a & mask if b > 0 else a
def sum_array_without_arithmetic(arr):
    if not arr:
        return 0
        
    result = arr[0]
    for num in arr[1:]:
        result = add_two_numbers(result, num)
    return result
print(sum_array_without_arithmetic([1, 2, 3, 4]))  
print(sum_array_without_arithmetic([10, -3, 5]))   
