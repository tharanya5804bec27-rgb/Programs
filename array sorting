def sort_binary_array(arr):
    left = 0
    right = len(arr) - 1
    while left < right:
        while left < right and arr[left] == 0:
            left += 1
        while left < right and arr[right] == 1:
            right -= 1
        if left < right:
            arr[left], arr[right] = arr[right], arr[left]
            left += 1
            right -= 1
            
    return arr
user_input = input("Enter an array of 0s and 1s separated by spaces: ")
try:
    binary_array = [int(x) for x in user_input.strip().split()]
    if any(num not in (0, 1) for num in binary_array):
        print("Error: The array must contain only 0s and 1s.")
    else:
        sorted_array = sort_binary_array(binary_array)
        print("Sorted Array:", " ".join(map(str, sorted_array)))
        
except ValueError:
    print("Error: Please enter numbers only.")
