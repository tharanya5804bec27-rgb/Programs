#include <iostream>
#include <vector>
#include <algorithm> 
using namespace std;
int main() {
    int n, k;
    cout << "Enter the number of elements in the array: ";
    cin >> n;
    vector<int> nums(n);
    cout << "Enter the number : ";
    for (int i = 0; i < n; i++) {
        std::cin >> nums[i];
    }
    cout << "Enter the value of K: ";
    cin >> k;
    if (k < 1 || k > n) {
        cout << "Invalid value of K! Must be between 1 and " << n << ".\n";
        return 1;
    }
    sort(nums.begin(), nums.end(), std::greater<int>());
    cout << "The " << k << "th largest element is: " << nums[k - 1] << endl;

    return 0;
}
