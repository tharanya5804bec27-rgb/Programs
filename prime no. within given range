#include <iostream>
#include <cmath>
int main() {
    int start, end;
    std::cout << "Enter starting number: ";
    std::cin >> start;
    std::cout << "Enter ending number: ";
    std::cin >> end;
    std::cout << "Prime numbers between " << start << " and " << end << ": ";
    for (int num = start; num <= end; num++) {
        if (num < 2) continue; 
        bool isPrime = true;
        for (int i = 2; i <= std::sqrt(num); i++) {
            if (num % i == 0) {
                isPrime = false; 
                break; 
            }
        }
        if (isPrime) {
            std::cout << num << " ";
        }
    }
    std::cout << std::endl;
    return 0;
}
